# Upstash Redis - create a free database at https://console.upstash.com/redis
# Copy these from your Upstash dashboard (REST API section)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Optional: set to "production" to enable cron warm-keeping on Vercel
NODE_ENV=development
